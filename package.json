{
  "name": "lumina-gem",
  "version": "1.0.0",
  "description": "Render a beautiful 3D rotating gem from any string",
  "main": "dist/lumina-gem.umd.js",
  "module": "dist/lumina-gem.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "node test/geometry-dna.test.mjs",
    "dev": "concurrently -n lib,web -c magenta,cyan \"rollup -c -w\" \"npm run dev --prefix website\"",
    "dev:lib": "rollup -c -w",
    "website:dev": "npm run dev --prefix website",
    "website:build": "npm run build --prefix website",
    "website:preview": "npm run preview --prefix website"
  },
  "keywords": [
    "gem",
    "3d",
    "webgl",
    "three",
    "renderer"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://lumina-gem.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/titangmz/lumina-gem"
  },
  "bugs": {
    "url": "https://github.com/titangmz/lumina-gem/issues"
  },
  "author": "titangmz",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/three": "^0.184.1",
    "concurrently": "^10.0.3",
    "rollup": "^4.0.0",
    "three": "^0.165.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  }
}
