{
  "name": "seedstone",
  "version": "2.0.0",
  "description": "Render a 3D rotating gem from any string",
  "keywords": [
    "3d",
    "avatar",
    "deterministic",
    "gem",
    "gemstone",
    "generative",
    "identicon",
    "three",
    "threejs",
    "wallet",
    "webgl"
  ],
  "homepage": "https://seedstone.xyz",
  "bugs": {
    "url": "https://github.com/titangmz/seedstone/issues"
  },
  "license": "MIT",
  "author": "titangmz",
  "repository": {
    "type": "git",
    "url": "https://github.com/titangmz/seedstone"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/seedstone.umd.js",
  "module": "dist/seedstone.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/seedstone.esm.js",
      "require": "./dist/seedstone.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm build:types && rolldown -c",
    "build:types": "tsc -p tsconfig.json --declaration --emitDeclarationOnly --declarationDir dist",
    "build:rollup": "pnpm build:types && rollup -c",
    "build:js": "rolldown -c",
    "build:js:rollup": "rollup -c",
    "build:compare": "node build/compare.js",
    "pretest": "pnpm build",
    "test": "vitest run",
    "prepublishOnly": "pnpm test",
    "dev": "pnpm build && concurrently -n lib,web -c magenta,cyan \"rolldown -c -w\" \"pnpm --filter seedstone-website dev\"",
    "dev:lib": "rolldown -c -w",
    "website:dev": "pnpm --filter seedstone-website dev",
    "website:build": "pnpm --filter seedstone-website build",
    "website:preview": "pnpm --filter seedstone-website preview",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@svgdotjs/svg.js": "^3.2.5",
    "@types/three": "^0.184.1",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "rolldown": "^1.1.2",
    "rollup": "^4.0.0",
    "svgdom": "^0.1.23",
    "three": "^0.184.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
