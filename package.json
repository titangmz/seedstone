{
  "name": "seedstone",
  "version": "2.0.0",
  "description": "Render a 3D rotating gem from any string",
  "keywords": [
    "3d",
    "avatar",
    "deterministic",
    "gem",
    "gemstone",
    "generative",
    "identicon",
    "three",
    "threejs",
    "wallet",
    "webgl"
  ],
  "homepage": "https://seedstone.xyz",
  "bugs": {
    "url": "https://github.com/titangmz/seedstone/issues"
  },
  "license": "MIT",
  "author": "titangmz",
  "repository": {
    "type": "git",
    "url": "https://github.com/titangmz/seedstone"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/seedstone.umd.js",
  "module": "dist/seedstone.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/seedstone.esm.js",
      "require": "./dist/seedstone.umd.js"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "pretest": "npm run build",
    "test": "vitest run",
    "prepublishOnly": "npm test",
    "dev": "concurrently -n lib,web -c magenta,cyan \"rollup -c -w\" \"npm run dev --prefix website\"",
    "dev:lib": "rollup -c -w",
    "website:dev": "npm run dev --prefix website",
    "website:build": "npm run build --prefix website",
    "website:preview": "npm run preview --prefix website",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/three": "^0.184.1",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "rollup": "^4.0.0",
    "three": "^0.184.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
