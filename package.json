{
  "name": "seedstone",
  "version": "1.0.0",
  "description": "Render a beautiful 3D rotating gem from any string",
  "main": "dist/seedstone.umd.js",
  "module": "dist/seedstone.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/seedstone.esm.js",
      "require": "./dist/seedstone.umd.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm test",
    "dev": "concurrently -n lib,web -c magenta,cyan \"rollup -c -w\" \"npm run dev --prefix website\"",
    "dev:lib": "rollup -c -w",
    "website:dev": "npm run dev --prefix website",
    "website:build": "npm run build --prefix website",
    "website:preview": "npm run preview --prefix website"
  },
  "keywords": [
    "gem",
    "gemstone",
    "3d",
    "webgl",
    "three",
    "threejs",
    "identicon",
    "avatar",
    "generative",
    "deterministic"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://seedstone.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/titangmz/seedstone"
  },
  "bugs": {
    "url": "https://github.com/titangmz/seedstone/issues"
  },
  "author": "titangmz",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/three": "^0.184.1",
    "concurrently": "^10.0.3",
    "rollup": "^4.0.0",
    "three": "^0.184.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  }
}
